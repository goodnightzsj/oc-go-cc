[Unit]
Description=oc-go-cc source watcher
After=network-online.target oc-go-cc.service
Wants=network-online.target
ConditionPathExists=/root/oc-go-cc/.enable-prod-watch

[Service]
Type=simple
User=root
WorkingDirectory=/root/oc-go-cc
ExecStart=/root/oc-go-cc/scripts/prod-watch.sh
Restart=always
RestartSec=5
Environment=HOME=/root
EnvironmentFile=-/root/oc-go-cc/.env
NoNewPrivileges=yes
PrivateTmp=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
